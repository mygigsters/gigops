# GigOps — LLM Provider Configuration
# =====================================
# Choose your provider: anthropic (default) | openai | gemini | ollama
GIGOPS_PROVIDER=anthropic

# --- Anthropic (recommended) ---
ANTHROPIC_API_KEY=sk-ant-...
# GIGOPS_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- OpenAI ---
# OPENAI_API_KEY=sk-...
# GIGOPS_OPENAI_MODEL=gpt-4o

# --- Google Gemini ---
# GEMINI_API_KEY=AI...
# GIGOPS_GEMINI_MODEL=gemini-2.0-flash

# --- Ollama (local, free) ---
# OLLAMA_HOST=http://localhost:11434
# GIGOPS_OLLAMA_MODEL=llama3
