{
  "name": "gigops",
  "version": "0.1.0",
  "description": "AI-powered gig search command center for freelancers. Companies use AI to filter gig workers. This gives gig workers AI to choose their gigs.",
  "main": "dist/index.js",
  "bin": {
    "gigops": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "doctor": "node dist/scripts/doctor.js",
    "batch": "node dist/scripts/batch.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts' 'scripts/**/*.ts'"
  },
  "keywords": [
    "freelance",
    "gig-economy",
    "ai",
    "upwork",
    "airtasker",
    "freelancer",
    "mygigsters"
  ],
  "author": "MyGigsters <hello@mygigsters.com.au>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mygigsters/gigops.git"
  },
  "homepage": "https://github.com/mygigsters/gigops#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@google/generative-ai": "^0.24.1",
    "@inquirer/prompts": "^8.4.1",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "figlet": "^1.7.0",
    "gradient-string": "^2.0.2",
    "inquirer": "^9.2.20",
    "js-yaml": "^4.1.0",
    "ollama": "^0.6.3",
    "openai": "^6.34.0",
    "ora": "^8.0.1",
    "playwright": "^1.43.0",
    "table": "^6.8.1",
    "vitest": "^4.1.4"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.5.0",
    "@typescript-eslint/parser": "^7.5.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bugs": {
    "url": "https://github.com/mygigsters/gigops/issues"
  },
  "files": [
    "dist/",
    "config/",
    "templates/",
    "README.md",
    "LICENSE"
  ]
}
